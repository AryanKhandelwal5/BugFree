# Copy to .env; never commit a real value.
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://codepilot:codepilot@postgres:5432/codepilot
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
ALLOWED_ORIGINS=http://localhost:3000
ENABLE_METRICS=true
FEATURE_HEALTH_DETAILS=true
JWT_SECRET_KEY=replace-with-a-32-byte-minimum-random-secret
JWT_ISSUER=codepilot-ai
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
AUTH_RATE_LIMIT_PER_MINUTE=10
